  "query": "\n        SELECT id, initiator_id, target_id, status AS \"status: MatchStatus\"\n        FROM matches\n        WHERE 1=1\n        AND (initiator_id = $1 OR target_id = $1)\n        AND matches.status != 'declined'\n        ",
