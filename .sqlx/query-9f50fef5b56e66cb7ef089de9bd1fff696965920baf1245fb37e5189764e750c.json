{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT c.id,\n               c.name,\n               c.password,\n               c.created_at,\n               c.updated_at,\n               c.active,\n               c.avatar_filename,\n               c.biography,\n               c.age,\n               cat_breeds.id AS breed_id,\n               cat_breeds.name AS breed_name\n        FROM cats c\n        JOIN cat_breeds ON c.breed_id = cat_breeds.id\n        LEFT JOIN matches m\n            ON (m.initiator_id = c.id OR m.target_id = c.id)\n        WHERE m.id IS NULL\n        AND c.id = $1\n        ",
