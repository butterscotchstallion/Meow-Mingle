  "query": "\n        SELECT cp.cat_id,\n               p.id AS photo_id,\n               p.\"order\",\n               p.created_at,\n               p.filename\n        FROM cats_photos cp\n        JOIN photos p ON cp.photo_id = p.id\n        ORDER BY cp.cat_id, p.\"order\" ASC NULLS LAST\n        ",
